{
    "name": "lamoda/fashion-store",
    "description": "La Moda - Fashion E-Commerce Store",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "mongodb/mongodb": "^1.17",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "LaModa\\": "src/"
        }
    }
}
